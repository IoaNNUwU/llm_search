# Copy to .env and adjust as needed: cp .env.example .env

# PostgreSQL (used by compose for postgres, migrate, and web)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# Ollama models (chat model is required; embed model has a compose default)
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_HOST=http://ollama:11434

# Set to "all" to enable GPU for Ollama (requires NVIDIA Container Toolkit). Default is CPU-only (0).
OLLAMA_GPU=0

# Application paths (inside the web container)
PROJECTS_PATH=/var/www/projects
